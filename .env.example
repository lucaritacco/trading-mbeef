# Copiá este archivo como .env.local y completá con tus credenciales de Supabase.
# Panel de Supabase → Project Settings → API.
# La anon (publishable) key es pública por diseño: viaja al navegador. Lo que
# NUNCA va acá ni al cliente es la service_role key (esa es secreta, solo en el servidor).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# URL pública del sitio en producción (para Open Graph / previews de WhatsApp).
# En local podés dejarlo sin setear (usa http://localhost:3000).
# En Vercel: poné el dominio real, ej. https://decarnes.vercel.app
NEXT_PUBLIC_SITE_URL=https://TU-DOMINIO.vercel.app
